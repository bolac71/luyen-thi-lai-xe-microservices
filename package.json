{
  "name": "luyen-thi-lai-xe-microservices",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run start:dev --filter=\"./apps/*\"",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.1",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@11.6.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@nestjs/microservices": "^11.1.17",
    "amqp-connection-manager": "^5.0.0",
    "amqplib": "^1.0.3"
  }
}
